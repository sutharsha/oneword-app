# Supabase project URL (from Settings > API in Supabase dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase anon/public key (from Settings > API in Supabase dashboard)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role key (from Settings > API — secret, never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Site URL for auth redirects (your deployed URL or http://localhost:3000 for local dev)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
